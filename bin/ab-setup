#!/bin/bash
# Agent Brain Setup Wizard
# Usage: bin/ab-setup (or: npm run setup)
#
# Interactive setup for new Agent Brain installations.
# Walks through .env creation, Supabase connection, and project configuration.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_DIR"

echo "╔══════════════════════════════════════════╗"
echo "║     Agent Brain Setup Wizard             ║"
echo "╚══════════════════════════════════════════╝"
echo ""

# ── Step 1: .env ──────────────────────────────────────────────────────────

if [ -f ".env" ]; then
  echo "✓ .env file exists"
  echo ""
  read -p "  Overwrite with fresh config? (y/N): " overwrite
  if [ "$overwrite" != "y" ] && [ "$overwrite" != "Y" ]; then
    echo "  Keeping existing .env"
    SKIP_ENV=true
  fi
fi

if [ "${SKIP_ENV:-}" != "true" ]; then
  echo ""
  echo "── Step 1: Environment Configuration ──────────"
  echo ""
  echo "You'll need a Supabase project. Create one free at: https://supabase.com"
  echo "Find your keys at: Settings → API"
  echo ""

  read -p "  Supabase URL (https://xxx.supabase.co): " SUPABASE_URL
  read -p "  Supabase Service Role Key: " SUPABASE_KEY
  echo ""

  echo "  Optional (press Enter to skip):"
  read -p "  Anthropic API Key (for AI features): " ANTHROPIC_KEY
  read -p "  ntfy.sh topic name (for push notifications): " NTFY_TOPIC

  # Generate encryption key
  AUTH_KEY=$(openssl rand -hex 32 2>/dev/null || python3 -c "import secrets; print(secrets.token_hex(32))" 2>/dev/null || echo "replace-with-64-char-hex")

  cat > .env <<EOF
# Agent Brain Environment Configuration
# Generated by ab-setup on $(date +%Y-%m-%d)

# ── Required ──────────────────────────────────────────────────────────────
SUPABASE_URL=$SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_KEY

# Encryption key for OAuth tokens
AUTH_ENCRYPTION_KEY=$AUTH_KEY

# ── Optional ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=${ANTHROPIC_KEY:-}
NTFY_TOPIC=${NTFY_TOPIC:-}

# Uncomment and fill in for additional features:
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=http://localhost:3030/api/email/accounts/callback
# GITHUB_TOKEN=
# GITHUB_WEBHOOK_SECRET=
EOF

  echo ""
  echo "✓ .env created"
fi

# ── Step 2: projects.json ─────────────────────────────────────────────────

echo ""
if [ -f "projects.json" ]; then
  echo "✓ projects.json exists"
else
  echo "── Step 2: Project Configuration ──────────────"
  echo ""
  echo "  Agent Brain tracks your coding projects for memory and sessions."
  echo ""
  read -p "  Add a project now? (Y/n): " add_project
  if [ "$add_project" != "n" ] && [ "$add_project" != "N" ]; then
    read -p "  Project name (e.g., my-app): " PROJ_NAME
    read -p "  Project directory (e.g., /Users/you/my-app): " PROJ_DIR

    # Convert path to project key format
    PROJ_KEY=$(echo "$PROJ_DIR" | sed 's|/|-|g')

    cat > projects.json <<EOF
{
  "$PROJ_NAME": {
    "dir": "$PROJ_KEY",
    "name": "$PROJ_NAME",
    "cwd": "$PROJ_DIR",
    "default_branch": "main"
  }
}
EOF
    echo ""
    echo "✓ projects.json created with project: $PROJ_NAME"
  else
    cp projects.example.json projects.json 2>/dev/null || echo "{}" > projects.json
    echo "✓ projects.json created (edit later to add your projects)"
  fi
fi

# ── Step 3: Install dependencies ──────────────────────────────────────────

echo ""
echo "── Step 3: Dependencies ──────────────────────"
if [ -d "node_modules" ]; then
  echo "✓ node_modules exists"
  read -p "  Reinstall? (y/N): " reinstall
  if [ "$reinstall" = "y" ] || [ "$reinstall" = "Y" ]; then
    npm install
  fi
else
  echo "  Installing dependencies..."
  npm install
fi

# ── Step 4: Test Supabase connection ──────────────────────────────────────

echo ""
echo "── Step 4: Connection Test ───────────────────"

# Source .env for testing
set -a
source .env 2>/dev/null
set +a

if [ -n "$SUPABASE_URL" ] && [ -n "$SUPABASE_SERVICE_ROLE_KEY" ]; then
  echo "  Testing Supabase connection..."
  HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
    "$SUPABASE_URL/rest/v1/" \
    -H "apikey: $SUPABASE_SERVICE_ROLE_KEY" \
    -H "Authorization: Bearer $SUPABASE_SERVICE_ROLE_KEY" 2>/dev/null || echo "000")

  if [ "$HTTP_CODE" = "200" ]; then
    echo "✓ Supabase connection successful"
  else
    echo "⚠ Supabase connection returned HTTP $HTTP_CODE"
    echo "  Check your SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in .env"
  fi
else
  echo "⚠ Supabase credentials not set — skipping connection test"
fi

# ── Step 5: Generate instruction files ────────────────────────────────────

echo ""
echo "── Step 5: Instruction Files ─────────────────"
if [ -f "instructions/generate.sh" ]; then
  bash instructions/generate.sh
else
  echo "⚠ instructions/generate.sh not found"
fi

# ── Step 6: Background Service (macOS LaunchAgent) ────────────────────────

echo ""
echo "── Step 6: Background Service ────────────────"

if [ "$(uname)" = "Darwin" ]; then
  PLIST_PATH="$HOME/Library/LaunchAgents/com.agentbrain.server.plist"
  echo "  Agent Brain can start automatically when you log in."
  echo ""
  read -p "  Install as background service? (Y/n): " install_service
  if [ "$install_service" != "n" ] && [ "$install_service" != "N" ]; then
    NODE_PATH=$(which node)
    cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentbrain.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>$NODE_PATH</string>
        <string>$PROJECT_DIR/server.js</string>
    </array>
    <key>WorkingDirectory</key>
    <string>$PROJECT_DIR</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>$PROJECT_DIR/logs/agent-brain.log</string>
    <key>StandardErrorPath</key>
    <string>$PROJECT_DIR/logs/agent-brain-error.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
PLIST

    mkdir -p "$PROJECT_DIR/logs"
    # Unload existing if present, then load new
    launchctl unload "$PLIST_PATH" 2>/dev/null || true
    launchctl load "$PLIST_PATH"
    echo "✓ LaunchAgent installed — Agent Brain will start on login"
    echo "  Logs: $PROJECT_DIR/logs/agent-brain.log"
    echo ""
    echo "  To stop: launchctl unload $PLIST_PATH"
    echo "  To start: launchctl load $PLIST_PATH"
    echo "  To remove: rm $PLIST_PATH"
  else
    echo "  Skipped. Start manually with: npm start"
  fi
elif [ -f "/etc/systemd/system" ] || command -v systemctl &>/dev/null; then
  echo "  Linux detected. To run Agent Brain as a service:"
  echo ""
  echo "  sudo tee /etc/systemd/system/agent-brain.service <<EOF"
  echo "  [Unit]"
  echo "  Description=Agent Brain"
  echo "  After=network.target"
  echo ""
  echo "  [Service]"
  echo "  Type=simple"
  echo "  User=$USER"
  echo "  WorkingDirectory=$PROJECT_DIR"
  echo "  ExecStart=$(which node) $PROJECT_DIR/server.js"
  echo "  Restart=on-failure"
  echo ""
  echo "  [Install]"
  echo "  WantedBy=multi-user.target"
  echo "  EOF"
  echo ""
  echo "  sudo systemctl enable agent-brain && sudo systemctl start agent-brain"
else
  echo "  Start manually with: npm start"
fi

# ── Done ──────────────────────────────────────────────────────────────────

echo ""
echo "╔══════════════════════════════════════════╗"
echo "║       Setup Complete!                    ║"
echo "╚══════════════════════════════════════════╝"
echo ""

# Show local IP for phone access
LOCAL_IP=$(ipconfig getifaddr en0 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")
echo "  Dashboard: http://localhost:3030"
if [ "$LOCAL_IP" != "localhost" ]; then
  echo "  From phone (same WiFi): http://$LOCAL_IP:3030"
fi
echo ""
echo "  Database migrations run automatically on startup."
echo ""
echo "  For remote phone access (away from WiFi):"
echo "    See SETUP.md for Tailscale or Cloudflare Tunnel setup"
echo ""
echo "  To customize Agent Brain:"
echo "    1. Copy instructions/local.example.md → instructions/local.md"
echo "    2. Edit with your preferences"
echo "    3. Run: npm run generate"
echo ""
echo "  To update later: bin/ab-update"
echo ""
