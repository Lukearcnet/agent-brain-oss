#!/bin/bash
# Agent Brain Setup Wizard
# Usage: bin/ab-setup (or: npm run setup)
#
# Interactive setup for new Agent Brain installations.
# Walks through .env creation, Supabase connection, and project configuration.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_DIR"

echo "╔══════════════════════════════════════════╗"
echo "║     Agent Brain Setup Wizard             ║"
echo "╚══════════════════════════════════════════╝"
echo ""

# ── Step 1: .env ──────────────────────────────────────────────────────────

if [ -f ".env" ]; then
  echo "✓ .env file exists"
  echo ""
  read -p "  Overwrite with fresh config? (y/N): " overwrite
  if [ "$overwrite" != "y" ] && [ "$overwrite" != "Y" ]; then
    echo "  Keeping existing .env"
    SKIP_ENV=true
  fi
fi

if [ "${SKIP_ENV:-}" != "true" ]; then
  echo ""
  echo "── Step 1: Environment Configuration ──────────"
  echo ""
  echo "You'll need a Supabase project. Create one free at: https://supabase.com"
  echo ""
  echo "  Where to find your credentials in Supabase Dashboard:"
  echo "    1. Go to Settings → API"
  echo "    2. Project URL: copy the URL at the top (https://xxxxx.supabase.co)"
  echo "    3. Service Role Key: under 'Project API keys', click Reveal on 'service_role'"
  echo "       (This is a long JWT starting with 'eyJ...' — copy the FULL key)"
  echo "       ⚠ Do NOT use the 'anon' key — it won't have write permissions"
  echo ""

  read -p "  Supabase URL (https://xxx.supabase.co): " SUPABASE_URL
  read -p "  Supabase Secret Key: " SUPABASE_KEY
  echo ""

  # Validate Supabase URL format
  if ! echo "$SUPABASE_URL" | grep -qE '^https://[a-zA-Z0-9_-]+\.supabase\.co/?$'; then
    echo "  ⚠ URL doesn't look like a standard Supabase URL (expected https://xxx.supabase.co)"
    echo "    Make sure you copied the full Project URL from Settings → API"
    echo ""
  fi

  # Validate Supabase key format and length
  KEY_LEN=${#SUPABASE_KEY}
  if [ "$KEY_LEN" -lt 100 ]; then
    echo "  ⚠ Key looks too short ($KEY_LEN chars). Supabase service_role keys are usually 200+ characters."
    echo "    Make sure you copied the FULL key from Settings → API → service_role (not the anon key)."
    echo "    The key should start with 'eyJ' (it's a JWT token)."
    echo ""
  elif ! echo "$SUPABASE_KEY" | grep -qE '^eyJ'; then
    echo "  ⚠ Key doesn't start with 'eyJ' — make sure this is the service_role key, not the anon key."
    echo "    Find it at: Settings → API → service_role (click 'Reveal' to see the full key)"
    echo ""
  fi

  echo "  Optional (press Enter to skip):"
  read -p "  Anthropic API Key (for AI features): " ANTHROPIC_KEY
  read -p "  ntfy.sh topic name (for push notifications): " NTFY_TOPIC

  # Generate encryption key
  AUTH_KEY=$(openssl rand -hex 32 2>/dev/null || python3 -c "import secrets; print(secrets.token_hex(32))" 2>/dev/null || echo "replace-with-64-char-hex")

  cat > .env <<EOF
# Agent Brain Environment Configuration
# Generated by ab-setup on $(date +%Y-%m-%d)

# ── Required ──────────────────────────────────────────────────────────────
SUPABASE_URL=$SUPABASE_URL
# Secret key (sb_secret_...) or legacy service_role key — from Settings → API Keys
SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_KEY

# Encryption key for OAuth tokens
AUTH_ENCRYPTION_KEY=$AUTH_KEY

# ── Optional ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=${ANTHROPIC_KEY:-}
NTFY_TOPIC=${NTFY_TOPIC:-}

# Agent Brain URL (auto-detected; change if using a custom domain)
AB_URL=http://localhost:3030

# Uncomment and fill in for additional features:
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=http://localhost:3030/api/email/accounts/callback
# GITHUB_TOKEN=
# GITHUB_WEBHOOK_SECRET=
EOF

  echo ""
  echo "✓ .env created"
fi

# ── Step 2: projects.json ─────────────────────────────────────────────────

echo ""
if [ -f "projects.json" ]; then
  echo "✓ projects.json exists"
else
  echo "── Step 2: Project Configuration ──────────────"
  echo ""
  echo "  Agent Brain tracks your coding projects for memory and sessions."
  echo ""
  read -p "  Add a project now? (Y/n): " add_project
  if [ "$add_project" != "n" ] && [ "$add_project" != "N" ]; then
    read -p "  Project name (e.g., my-app): " PROJ_NAME
    read -p "  Project directory (e.g., /Users/you/my-app): " PROJ_DIR

    # Convert path to project key format
    PROJ_KEY=$(echo "$PROJ_DIR" | sed 's|/|-|g')

    cat > projects.json <<EOF
{
  "$PROJ_NAME": {
    "dir": "$PROJ_KEY",
    "name": "$PROJ_NAME",
    "cwd": "$PROJ_DIR",
    "default_branch": "main"
  }
}
EOF
    echo ""
    echo "✓ projects.json created with project: $PROJ_NAME"
  else
    cp projects.example.json projects.json 2>/dev/null || echo "{}" > projects.json
    echo "✓ projects.json created (edit later to add your projects)"
  fi
fi

# ── Step 3: Install dependencies ──────────────────────────────────────────

echo ""
echo "── Step 3: Dependencies ──────────────────────"
if [ -d "node_modules" ]; then
  echo "✓ node_modules exists"
  read -p "  Reinstall? (y/N): " reinstall
  if [ "$reinstall" = "y" ] || [ "$reinstall" = "Y" ]; then
    npm install
  fi
else
  echo "  Installing dependencies..."
  npm install
fi

# ── Step 4: Test Supabase connection ──────────────────────────────────────

echo ""
echo "── Step 4: Connection Test ───────────────────"

# Source .env for testing
set -a
source .env 2>/dev/null
set +a

if [ -n "$SUPABASE_URL" ] && [ -n "$SUPABASE_SERVICE_ROLE_KEY" ]; then
  echo "  Testing Supabase connection..."

  # Test 1: Basic connectivity (GET)
  HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
    "$SUPABASE_URL/rest/v1/" \
    -H "apikey: $SUPABASE_SERVICE_ROLE_KEY" \
    -H "Authorization: Bearer $SUPABASE_SERVICE_ROLE_KEY" 2>/dev/null || echo "000")

  if [ "$HTTP_CODE" = "200" ]; then
    echo "  ✓ Supabase API reachable"
  elif [ "$HTTP_CODE" = "401" ] || [ "$HTTP_CODE" = "403" ]; then
    echo "  ✗ Authentication failed (HTTP $HTTP_CODE)"
    echo "    Your API key was rejected. Make sure you're using the service_role key (not anon key)."
    echo "    Find it at: Supabase Dashboard → Settings → API → service_role → Reveal"
  elif [ "$HTTP_CODE" = "000" ]; then
    echo "  ✗ Could not reach Supabase at $SUPABASE_URL"
    echo "    Check your SUPABASE_URL — it should be https://xxxxx.supabase.co"
  else
    echo "  ⚠ Supabase returned HTTP $HTTP_CODE"
    echo "    Check your SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in .env"
  fi

  # Test 2: Write capability (POST to RPC — tests service_role permissions)
  if [ "$HTTP_CODE" = "200" ]; then
    WRITE_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
      "$SUPABASE_URL/rest/v1/rpc/exec_sql" \
      -H "apikey: $SUPABASE_SERVICE_ROLE_KEY" \
      -H "Authorization: Bearer $SUPABASE_SERVICE_ROLE_KEY" \
      -H "Content-Type: application/json" \
      -d '{"query":"SELECT 1"}' 2>/dev/null || echo "000")

    if [ "$WRITE_CODE" = "200" ] || [ "$WRITE_CODE" = "204" ]; then
      echo "  ✓ Database RPC working (migrations will run automatically)"
    elif [ "$WRITE_CODE" = "404" ]; then
      echo "  ⚠ exec_sql RPC not found — you'll need to run bootstrap SQL on first start"
      echo "    The server will show instructions if needed."
    else
      echo "  ⚠ Database RPC returned HTTP $WRITE_CODE (may need bootstrap SQL)"
    fi
  fi

  echo ""
else
  echo "⚠ Supabase credentials not set — skipping connection test"
fi

# ── Step 5: Generate instruction files ────────────────────────────────────

echo ""
echo "── Step 5: Instruction Files ─────────────────"
if [ -f "instructions/generate.sh" ]; then
  bash instructions/generate.sh
  # Verify CLAUDE.md was placed globally
  if [ -f "$HOME/.claude/CLAUDE.md" ]; then
    echo "✓ Claude Code will auto-adopt Agent Brain in all future sessions"
  else
    echo "⚠ Global CLAUDE.md not created. Creating now..."
    mkdir -p "$HOME/.claude"
    cp "$PROJECT_DIR/CLAUDE.md" "$HOME/.claude/CLAUDE.md" 2>/dev/null || echo "  Failed — copy CLAUDE.md to ~/.claude/ manually"
  fi
else
  echo "⚠ instructions/generate.sh not found"
fi

# ── Step 6: Claude Code Hooks ──────────────────────────────────────────────

echo ""
echo "── Step 6: Claude Code Hooks ─────────────────"

CLAUDE_SETTINGS="$HOME/.claude/settings.json"
HOOK_SCRIPT="$PROJECT_DIR/hooks/permission-hook.sh"
MSG_HOOK_SCRIPT="$PROJECT_DIR/hooks/message-check-hook.sh"

# Make hook scripts executable
chmod +x "$HOOK_SCRIPT" 2>/dev/null
chmod +x "$MSG_HOOK_SCRIPT" 2>/dev/null

if [ -f "$CLAUDE_SETTINGS" ]; then
  # Check if hooks are already configured
  if python3 -c "
import json, sys
with open('$CLAUDE_SETTINGS') as f:
    d = json.load(f)
hooks = d.get('hooks', {})
if 'PermissionRequest' in hooks or 'PreToolUse' in hooks:
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
    echo "✓ Hooks already configured in settings.json"
  else
    # Merge hooks into existing settings
    python3 -c "
import json
with open('$CLAUDE_SETTINGS') as f:
    d = json.load(f)
d.setdefault('hooks', {})
d['hooks']['PreToolUse'] = [{'matcher': '', 'hooks': [{'type': 'command', 'command': '$MSG_HOOK_SCRIPT', 'timeout': 5}]}]
d['hooks']['PermissionRequest'] = [{'matcher': '', 'hooks': [{'type': 'command', 'command': '$HOOK_SCRIPT', 'timeout': 120}]}]
with open('$CLAUDE_SETTINGS', 'w') as f:
    json.dump(d, f, indent=2)
print('done')
" 2>/dev/null
    if [ $? -eq 0 ]; then
      echo "✓ Hooks configured — Agent Brain will handle permissions from your phone"
    else
      echo "⚠ Could not auto-configure hooks. Add manually to $CLAUDE_SETTINGS:"
      echo "    \"hooks\": {"
      echo "      \"PreToolUse\": [{\"matcher\": \"\", \"hooks\": [{\"type\": \"command\", \"command\": \"$MSG_HOOK_SCRIPT\", \"timeout\": 5}]}],"
      echo "      \"PermissionRequest\": [{\"matcher\": \"\", \"hooks\": [{\"type\": \"command\", \"command\": \"$HOOK_SCRIPT\", \"timeout\": 120}]}]"
      echo "    }"
    fi
  fi
else
  # Create settings.json with hooks
  mkdir -p "$HOME/.claude"
  python3 -c "
import json
d = {
    'hooks': {
        'PreToolUse': [{'matcher': '', 'hooks': [{'type': 'command', 'command': '$MSG_HOOK_SCRIPT', 'timeout': 5}]}],
        'PermissionRequest': [{'matcher': '', 'hooks': [{'type': 'command', 'command': '$HOOK_SCRIPT', 'timeout': 120}]}]
    }
}
with open('$CLAUDE_SETTINGS', 'w') as f:
    json.dump(d, f, indent=2)
print('done')
" 2>/dev/null
  if [ $? -eq 0 ]; then
    echo "✓ Created $CLAUDE_SETTINGS with Agent Brain hooks"
  else
    echo "⚠ Could not create settings.json. See SETUP.md for manual hook configuration."
  fi
fi

# ── Step 7: Background Service (macOS LaunchAgent) ────────────────────────

echo ""
echo "── Step 7: Background Service ─────────────────"

if [ "$(uname)" = "Darwin" ]; then
  PLIST_PATH="$HOME/Library/LaunchAgents/com.agentbrain.server.plist"
  echo "  Agent Brain can start automatically when you log in."
  echo ""
  read -p "  Install as background service? (Y/n): " install_service
  if [ "$install_service" != "n" ] && [ "$install_service" != "N" ]; then
    NODE_PATH=$(which node)
    cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentbrain.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>$NODE_PATH</string>
        <string>$PROJECT_DIR/server.js</string>
    </array>
    <key>WorkingDirectory</key>
    <string>$PROJECT_DIR</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>$PROJECT_DIR/logs/agent-brain.log</string>
    <key>StandardErrorPath</key>
    <string>$PROJECT_DIR/logs/agent-brain-error.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
PLIST

    mkdir -p "$PROJECT_DIR/logs"
    # Unload existing if present, then load new
    launchctl unload "$PLIST_PATH" 2>/dev/null || true
    launchctl load "$PLIST_PATH"
    echo "✓ LaunchAgent installed — Agent Brain will start on login"
    echo "  Logs: $PROJECT_DIR/logs/agent-brain.log"
    echo ""
    echo "  To stop: launchctl unload $PLIST_PATH"
    echo "  To start: launchctl load $PLIST_PATH"
    echo "  To remove: rm $PLIST_PATH"
  else
    echo "  Skipped. Start manually with: npm start"
  fi
elif [ -f "/etc/systemd/system" ] || command -v systemctl &>/dev/null; then
  echo "  Linux detected. To run Agent Brain as a service:"
  echo ""
  echo "  sudo tee /etc/systemd/system/agent-brain.service <<EOF"
  echo "  [Unit]"
  echo "  Description=Agent Brain"
  echo "  After=network.target"
  echo ""
  echo "  [Service]"
  echo "  Type=simple"
  echo "  User=$USER"
  echo "  WorkingDirectory=$PROJECT_DIR"
  echo "  ExecStart=$(which node) $PROJECT_DIR/server.js"
  echo "  Restart=on-failure"
  echo ""
  echo "  [Install]"
  echo "  WantedBy=multi-user.target"
  echo "  EOF"
  echo ""
  echo "  sudo systemctl enable agent-brain && sudo systemctl start agent-brain"
else
  echo "  Start manually with: npm start"
fi

# ── Step 8: Phone Access (Tailscale) ─────────────────────────────────────

echo ""
echo "── Step 8: Phone Access ──────────────────────"

LOCAL_IP=$(ipconfig getifaddr en0 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")
if [ "$LOCAL_IP" != "localhost" ]; then
  echo "  Same WiFi: http://$LOCAL_IP:3030"
fi

if command -v tailscale &>/dev/null; then
  TS_IP=$(tailscale ip -4 2>/dev/null || echo "")
  if [ -n "$TS_IP" ]; then
    echo "✓ Tailscale connected — access from anywhere: http://$TS_IP:3030"
    # Update AB_URL in .env so generated instructions use the Tailscale IP
    if grep -q '^AB_URL=' .env 2>/dev/null; then
      sed -i.bak "s|^AB_URL=.*|AB_URL=http://$TS_IP:3030|" .env && rm -f .env.bak
      echo "  Updated AB_URL in .env to http://$TS_IP:3030"
    fi
  else
    echo "✓ Tailscale installed but not connected"
    echo "  Run: tailscale up"
    echo "  Then access Agent Brain from anywhere via your Tailscale IP"
  fi
else
  echo ""
  echo "  For phone access from anywhere, install Tailscale (free):"
  if [ "$(uname)" = "Darwin" ]; then
    echo "    brew install tailscale && tailscale up"
  else
    echo "    curl -fsSL https://tailscale.com/install.sh | sh && sudo tailscale up"
  fi
  echo "  Then install the Tailscale app on your phone."
  echo "  Access Agent Brain from anywhere: http://<tailscale-ip>:3030"
fi

# ── Done ──────────────────────────────────────────────────────────────────

echo ""
echo "╔══════════════════════════════════════════╗"
echo "║       Setup Complete!                    ║"
echo "╚══════════════════════════════════════════╝"
echo ""

echo "  Dashboard: http://localhost:3030"
if [ "$LOCAL_IP" != "localhost" ]; then
  echo "  From phone (same WiFi): http://$LOCAL_IP:3030"
fi
echo ""
echo "  Database migrations run automatically on startup."
echo ""
echo "  To customize Agent Brain:"
echo "    1. Copy instructions/local.example.md → instructions/local.md"
echo "    2. Edit with your preferences"
echo "    3. Run: npm run generate"
echo ""
echo "  To update later: bin/ab-update"
echo ""
