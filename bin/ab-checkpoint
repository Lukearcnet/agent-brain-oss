#!/bin/bash
# ab-checkpoint - Atomic checkpoint wrapper for Agent Brain
# Combines checkpoint creation and polling into foolproof commands
#
# Usage:
#   ab-checkpoint cycle "question" "opt1" "opt2" ...   # Create + poll until response
#   ab-checkpoint ask "question" "opt1" "opt2" ...     # Create only (non-blocking)
#   ab-checkpoint wait <checkpoint_id>                  # Poll until response
#   ab-checkpoint wait-once [checkpoint_id]             # Poll once (Codex-friendly)
#   ab-checkpoint ready                                 # Check for a server-held ready response
#   ab-checkpoint consume                               # Fetch and clear a server-held ready response
#   ab-checkpoint status <checkpoint_id>                # Check status once
#   ab-checkpoint recover                               # Resume polling saved checkpoint
#
# Environment:
#   AB_HOST - Agent Brain server (default: http://localhost:3030)
#   AB_SESSION_ID - Agent Brain session ID (auto-resolves provider/project_dir)
#   AB_PROVIDER - Provider override (claude/codex)
#   AB_POLL_INTERVAL - Seconds between polls (default: 30)
#   AB_TIMEOUT - Max wait time in seconds (default: 86400 = 24 hours)

set -e

AB_HOST="${AB_HOST:-http://localhost:3030}"
AB_POLL_INTERVAL="${AB_POLL_INTERVAL:-30}"
AB_TIMEOUT="${AB_TIMEOUT:-86400}"

# Determine project key from current directory
PROJECT_KEY=$(pwd | sed 's|/|-|g')

# Checkpoint persistence file (for recovery after session restart)
CHECKPOINT_FILE="/tmp/ab-checkpoint-${AB_SESSION_ID:-$PROJECT_KEY}"

usage() {
  cat <<EOF
ab-checkpoint - Atomic checkpoint wrapper for Agent Brain

Commands:
  cycle "question" "opt1" "opt2" ...   Create checkpoint and poll until response
  ask "question" "opt1" "opt2" ...     Create checkpoint only (non-blocking)
  wait <checkpoint_id>                  Poll checkpoint until response
  wait-once [checkpoint_id]             Poll exactly once (recommended for Codex)
  ready                                 Check whether Agent Brain already holds a response for this session
  consume                               Fetch and clear a server-held ready response for this session
  status <checkpoint_id>                Check checkpoint status once
  recover                               Resume polling a saved checkpoint (from file or session lookup)

Options are optional. If none provided, user gets a free-form text input.

Environment variables:
  AB_SESSION_ID    Agent Brain session ID (enables server-side field resolution)
  AB_PROVIDER      Provider override (claude/codex)
  AB_HOST          Server URL (default: http://localhost:3030)
  AB_POLL_INTERVAL Poll interval in seconds (default: 30)
  AB_TIMEOUT       Max wait in seconds (default: 86400)

Examples:
  ab-checkpoint cycle "Ready to proceed with refactor?" "Yes" "No" "Modify approach"
  ab-checkpoint ask "Task complete. What's next?"
  ab-checkpoint wait ckpt-1234567890-abc123
  ab-checkpoint wait-once
  AB_SESSION_ID=20260309-120514 ab-checkpoint ready
  AB_SESSION_ID=20260309-120514 ab-checkpoint consume
  AB_SESSION_ID=20260309-120514 ab-checkpoint cycle "Question?" "A" "B"
  ab-checkpoint recover
EOF
  exit 1
}

# Save checkpoint ID for recovery
save_checkpoint_id() {
  local checkpoint_id="$1"
  echo "$checkpoint_id" > "$CHECKPOINT_FILE"
}

# Load saved checkpoint ID
load_checkpoint_id() {
  if [ -f "$CHECKPOINT_FILE" ]; then
    cat "$CHECKPOINT_FILE"
  fi
}

# Clean up saved checkpoint
clear_checkpoint_id() {
  rm -f "$CHECKPOINT_FILE"
}

fetch_ready_checkpoint() {
  if [ -z "${AB_SESSION_ID:-}" ]; then
    echo "AB_SESSION_ID is required to check ready responses." >&2
    exit 1
  fi
  curl -s "${AB_HOST}/api/sessions/${AB_SESSION_ID}/ready-checkpoint"
}

consume_ready_checkpoint() {
  if [ -z "${AB_SESSION_ID:-}" ]; then
    echo "AB_SESSION_ID is required to consume ready responses." >&2
    exit 1
  fi
  clear_checkpoint_id
  curl -s -X POST "${AB_HOST}/api/sessions/${AB_SESSION_ID}/consume-ready-checkpoint"
}

# Create a checkpoint (non-blocking)
create_checkpoint() {
  local question="$1"
  shift
  local options=("$@")

  # Build options JSON array
  local options_json="[]"
  if [ ${#options[@]} -gt 0 ]; then
    options_json=$(printf '%s\n' "${options[@]}" | jq -R . | jq -s .)
  fi

  # Build payload — include session_id if available (server resolves the rest)
  local payload
  if [ -n "$AB_SESSION_ID" ]; then
    payload=$(jq -n \
      --arg session_id "$AB_SESSION_ID" \
      --arg project_dir "$PROJECT_KEY" \
      --arg question "$question" \
      --argjson options "$options_json" \
      --arg provider "${AB_PROVIDER:-}" \
      '{session_id: $session_id, project_dir: $project_dir, question: $question, options: $options} + (if $provider != "" then {provider: $provider} else {} end)')
  else
    payload=$(jq -n \
      --arg project_dir "$PROJECT_KEY" \
      --arg question "$question" \
      --argjson options "$options_json" \
      '{project_dir: $project_dir, question: $question, options: $options}')
  fi

  local response=$(curl -s -X POST "${AB_HOST}/api/checkpoints?blocking=false" \
    -H "Content-Type: application/json" \
    -d "$payload")

  local checkpoint_id=$(echo "$response" | jq -r '.checkpoint_id // empty')

  if [ -z "$checkpoint_id" ]; then
    echo "Error creating checkpoint: $response" >&2
    exit 1
  fi

  # Persist checkpoint ID for recovery
  save_checkpoint_id "$checkpoint_id"

  echo "$checkpoint_id"
}

# Poll checkpoint until response
poll_checkpoint() {
  local checkpoint_id="$1"
  local start_time=$(date +%s)

  while true; do
    local elapsed=$(($(date +%s) - start_time))
    if [ $elapsed -ge $AB_TIMEOUT ]; then
      echo '{"status":"timeout","response":"Checkpoint timed out after '"$AB_TIMEOUT"' seconds"}'
      exit 1
    fi

    local response=$(curl -s "${AB_HOST}/api/checkpoints/${checkpoint_id}/wait?timeout=${AB_POLL_INTERVAL}")
    local status=$(echo "$response" | jq -r '.status // "error"')

    case "$status" in
      responded)
        # Clean up persistence file on successful response
        clear_checkpoint_id
        echo "$response"
        return 0
        ;;
      pending)
        # Continue polling
        ;;
      timeout)
        # Server poll timeout, continue our loop
        ;;
      *)
        echo "Error polling checkpoint: $response" >&2
        exit 1
        ;;
    esac
  done
}

# Poll checkpoint exactly once using the server wait endpoint.
# This avoids long-running local loops, which Codex tends to background.
poll_checkpoint_once() {
  local checkpoint_id="$1"
  local response=$(curl -s "${AB_HOST}/api/checkpoints/${checkpoint_id}/wait?timeout=${AB_POLL_INTERVAL}")
  local status=$(echo "$response" | jq -r '.status // "error"')

  if [ "$status" = "responded" ]; then
    clear_checkpoint_id
  fi

  echo "$response"
}

# Get checkpoint status without blocking
get_status() {
  local checkpoint_id="$1"
  curl -s "${AB_HOST}/api/checkpoints/${checkpoint_id}/status"
}

# Recover: find and resume polling a pending checkpoint
recover_checkpoint() {
  if [ -n "${AB_SESSION_ID:-}" ]; then
    local ready
    ready=$(fetch_ready_checkpoint 2>/dev/null || true)
    if [ -n "$ready" ] && [ "$(echo "$ready" | jq -r '.ready // false')" = "true" ]; then
      echo "Found ready response for session $AB_SESSION_ID." >&2
      consume_ready_checkpoint
      return
    fi
  fi

  # Strategy 1: Check saved checkpoint file
  local saved_id=$(load_checkpoint_id)
  if [ -n "$saved_id" ]; then
    echo "Found saved checkpoint: $saved_id" >&2
    local status=$(curl -s "${AB_HOST}/api/checkpoints/${saved_id}/status" | jq -r '.status // "error"')
    if [ "$status" = "pending" ]; then
      echo "Resuming polling..." >&2
      poll_checkpoint "$saved_id"
      return
    elif [ "$status" = "responded" ]; then
      echo "Checkpoint already responded:" >&2
      clear_checkpoint_id
      curl -s "${AB_HOST}/api/checkpoints/${saved_id}/status"
      return
    fi
    echo "Saved checkpoint is $status, clearing..." >&2
    clear_checkpoint_id
  fi

  # Strategy 2: Ask server for pending checkpoint by session_id
  if [ -n "$AB_SESSION_ID" ]; then
    echo "Looking up pending checkpoint for session $AB_SESSION_ID..." >&2
    local lookup=$(curl -s "${AB_HOST}/api/sessions/${AB_SESSION_ID}/pending-checkpoint")
    local pending=$(echo "$lookup" | jq -r '.pending // false')

    if [ "$pending" = "true" ]; then
      local ckpt_id=$(echo "$lookup" | jq -r '.checkpoint_id')
      echo "Found pending checkpoint: $ckpt_id" >&2
      save_checkpoint_id "$ckpt_id"
      poll_checkpoint "$ckpt_id"
      return
    fi
  fi

  echo "No pending checkpoint to recover." >&2
  exit 0
}

resolve_checkpoint_id() {
  local checkpoint_id="${1:-}"

  if [ -n "$checkpoint_id" ]; then
    save_checkpoint_id "$checkpoint_id"
    echo "$checkpoint_id"
    return 0
  fi

  if [ -n "${AB_SESSION_ID:-}" ]; then
    local ready
    ready=$(fetch_ready_checkpoint 2>/dev/null || true)
    if [ -n "$ready" ] && [ "$(echo "$ready" | jq -r '.ready // false')" = "true" ]; then
      echo "__READY__"
      return 0
    fi
  fi

  local saved_id
  saved_id=$(load_checkpoint_id)
  if [ -n "$saved_id" ]; then
    echo "$saved_id"
    return 0
  fi

  if [ -n "${AB_SESSION_ID:-}" ]; then
    local lookup
    lookup=$(curl -s "${AB_HOST}/api/sessions/${AB_SESSION_ID}/pending-checkpoint")
    local pending
    pending=$(echo "$lookup" | jq -r '.pending // false')
    if [ "$pending" = "true" ]; then
      local looked_up_id
      looked_up_id=$(echo "$lookup" | jq -r '.checkpoint_id // empty')
      if [ -n "$looked_up_id" ]; then
        save_checkpoint_id "$looked_up_id"
        echo "$looked_up_id"
        return 0
      fi
    fi
  fi

  echo "No checkpoint_id provided and no saved pending checkpoint found." >&2
  exit 1
}

wait_once_or_ready() {
  local resolved
  resolved=$(resolve_checkpoint_id "${1:-}")

  if [ "$resolved" = "__READY__" ]; then
    fetch_ready_checkpoint
    return 0
  fi

  poll_checkpoint_once "$resolved"
}

# Main command dispatch
case "${1:-}" in
  cycle)
    shift
    if [ $# -lt 1 ]; then
      echo "Error: cycle requires at least a question" >&2
      usage
    fi
    question="$1"
    shift

    # Create checkpoint
    checkpoint_id=$(create_checkpoint "$question" "$@")
    echo "Checkpoint created: $checkpoint_id" >&2
    echo "Waiting for response..." >&2

    # Poll until response
    poll_checkpoint "$checkpoint_id"
    ;;

  ask)
    shift
    if [ $# -lt 1 ]; then
      echo "Error: ask requires at least a question" >&2
      usage
    fi
    question="$1"
    shift

    checkpoint_id=$(create_checkpoint "$question" "$@")
    echo "$checkpoint_id"
    ;;

  wait)
    shift
    if [ $# -lt 1 ]; then
      echo "Error: wait requires a checkpoint_id" >&2
      usage
    fi
    # Save for recovery
    save_checkpoint_id "$1"
    poll_checkpoint "$1"
    ;;

  wait-once)
    shift
    wait_once_or_ready "${1:-}"
    ;;

  ready)
    fetch_ready_checkpoint
    ;;

  consume)
    consume_ready_checkpoint
    ;;

  status)
    shift
    if [ $# -lt 1 ]; then
      echo "Error: status requires a checkpoint_id" >&2
      usage
    fi
    get_status "$1"
    ;;

  recover)
    recover_checkpoint
    ;;

  -h|--help|help)
    usage
    ;;

  *)
    usage
    ;;
esac
